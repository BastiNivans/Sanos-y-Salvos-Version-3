{
  "info": {
    "name": "Sanos y Salvos - API REST",
    "description": "Colección de endpoints del BFF y los 3 microservicios (mascotas, coincidencias, geolocalizacion) del proyecto Sanos y Salvos. Incluye ejemplos de peticiones y respuestas para la Evaluación Parcial N°3 (DSY1106).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "bff_url", "value": "http://localhost:8080" },
    { "key": "mascotas_url", "value": "http://localhost:8081" },
    { "key": "coincidencias_url", "value": "http://localhost:8082" },
    { "key": "geo_url", "value": "http://localhost:8083" }
  ],
  "item": [
    {
      "name": "BFF (Gateway)",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"ana@test.com\",\n  \"contrasena\": \"clave123\"\n}"
            },
            "url": { "raw": "{{bff_url}}/api/login", "host": ["{{bff_url}}"], "path": ["api", "login"] }
          },
          "response": [
            {
              "name": "200 OK - Login exitoso",
              "code": 200,
              "status": "OK",
              "body": "{\n  \"mensaje\": \"Login exitoso\",\n  \"correo\": \"ana@test.com\",\n  \"token\": \"jwt-simulado-sanos-y-salvos-xyz123\"\n}"
            },
            {
              "name": "401 Unauthorized - Credenciales incorrectas",
              "code": 401,
              "status": "Unauthorized",
              "body": "{\n  \"error\": \"Credenciales incorrectas\"\n}"
            }
          ]
        },
        {
          "name": "Registro",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"nuevo@test.com\",\n  \"contrasena\": \"clave123\"\n}"
            },
            "url": { "raw": "{{bff_url}}/api/registro", "host": ["{{bff_url}}"], "path": ["api", "registro"] }
          },
          "response": [
            {
              "name": "201 Created",
              "code": 201,
              "status": "Created",
              "body": "{\n  \"mensaje\": \"¡Registro exitoso! Ya puedes iniciar sesión.\",\n  \"correo\": \"nuevo@test.com\"\n}"
            },
            {
              "name": "409 Conflict - Correo ya registrado",
              "code": 409,
              "status": "Conflict",
              "body": "{\n  \"error\": \"Este correo ya está registrado\"\n}"
            }
          ]
        },
        {
          "name": "Listar mascotas",
          "request": {
            "method": "GET",
            "url": { "raw": "{{bff_url}}/api/mascotas", "host": ["{{bff_url}}"], "path": ["api", "mascotas"] }
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "status": "OK",
              "body": "[\n  {\n    \"id\": 1,\n    \"especie\": \"Perro\",\n    \"raza\": \"Labrador\",\n    \"tipoReporte\": \"PERDIDA\",\n    \"ubicacion\": \"Puente Alto\",\n    \"imagenesUrls\": \"\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Registrar mascota (dispara cálculo de coincidencias)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"especie\": \"Perro\",\n  \"raza\": \"Labrador\",\n  \"tipoReporte\": \"PERDIDA\",\n  \"ubicacion\": \"Puente Alto\"\n}"
            },
            "url": { "raw": "{{bff_url}}/api/mascotas", "host": ["{{bff_url}}"], "path": ["api", "mascotas"] }
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "status": "OK",
              "body": "{\n  \"id\": 10,\n  \"especie\": \"Perro\",\n  \"raza\": \"Labrador\",\n  \"tipoReporte\": \"PERDIDA\",\n  \"ubicacion\": \"Puente Alto\",\n  \"imagenesUrls\": \"\"\n}"
            }
          ]
        },
        {
          "name": "Listar coincidencias",
          "request": {
            "method": "GET",
            "url": { "raw": "{{bff_url}}/api/coincidencias", "host": ["{{bff_url}}"], "path": ["api", "coincidencias"] }
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "status": "OK",
              "body": "[\n  {\n    \"id\": 1,\n    \"idMascotaPerdida\": 1,\n    \"idMascotaEncontrada\": 2,\n    \"nivelSimilitud\": 100.0,\n    \"fechaAnalisis\": \"2026-06-23T10:00:00\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Calcular coincidencias para mascota",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{bff_url}}/api/coincidencias/calcular/1",
              "host": ["{{bff_url}}"],
              "path": ["api", "coincidencias", "calcular", "1"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "status": "OK",
              "body": "[\n  {\n    \"id\": 1,\n    \"idMascotaPerdida\": 1,\n    \"idMascotaEncontrada\": 2,\n    \"nivelSimilitud\": 100.0,\n    \"fechaAnalisis\": \"2026-06-23T10:00:00\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Coincidencias de una mascota",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{bff_url}}/api/coincidencias/mascota/1",
              "host": ["{{bff_url}}"],
              "path": ["api", "coincidencias", "mascota", "1"]
            }
          },
          "response": []
        }
      ]
    },
    {
