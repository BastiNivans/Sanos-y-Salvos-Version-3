              "raw": "{\n  \"especie\": \"Gato\",\n  \"raza\": \"Persa\",\n  \"tipoReporte\": \"ENCONTRADA\",\n  \"ubicacion\": \"Macul\",\n  \"imagenesUrls\": \"\"\n}"
            },
            "url": { "raw": "{{mascotas_url}}/api/mascotas/1", "host": ["{{mascotas_url}}"], "path": ["api", "mascotas", "1"] }
