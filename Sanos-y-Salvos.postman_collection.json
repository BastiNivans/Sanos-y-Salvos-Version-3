        {
          "name": "Login usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"ana@test.com\",\n  \"contrasena\": \"clave123\"\n}"
            },
            "url": { "raw": "{{mascotas_url}}/api/usuarios/login", "host": ["{{mascotas_url}}"], "path": ["api", "usuarios", "login"] }
          },
          "response": []
        },
        {
          "name": "Registro usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"nuevo@test.com\",\n  \"contrasena\": \"clave123\"\n}"
            },
            "url": { "raw": "{{mascotas_url}}/api/usuarios/registro", "host": ["{{mascotas_url}}"], "path": ["api", "usuarios", "registro"] }
          },
          "response": []
        }
      ]
    },
    {
