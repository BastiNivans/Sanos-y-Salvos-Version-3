    {
      "name": "Geolocalizacion (microservicio directo)",
      "item": [
        {
          "name": "Registrar ubicación",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{geo_url}}/api/geolocalizacion/registrar?idMascota=1&especie=Perro&raza=Labrador&tipoReporte=PERDIDA&latitud=-33.45&longitud=-70.65&direccionTexto=Puente Alto",
              "host": ["{{geo_url}}"],
              "path": ["api", "geolocalizacion", "registrar"],
              "query": [
                { "key": "idMascota", "value": "1" },
                { "key": "especie", "value": "Perro" },
                { "key": "raza", "value": "Labrador" },
                { "key": "tipoReporte", "value": "PERDIDA" },
                { "key": "latitud", "value": "-33.45" },
                { "key": "longitud", "value": "-70.65" },
                { "key": "direccionTexto", "value": "Puente Alto" }
              ]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "status": "OK",
              "body": "{\n  \"id\": 1,\n  \"idMascota\": 1,\n  \"especie\": \"Perro\",\n  \"raza\": \"Labrador\",\n  \"tipoReporte\": \"PERDIDA\",\n  \"latitud\": -33.45,\n  \"longitud\": -70.65,\n  \"direccionTexto\": \"Puente Alto\"\n}"
            }
          ]
        },
        {
          "name": "Buscar cercanas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{geo_url}}/api/geolocalizacion/cercanas?latitud=-33.45&longitud=-70.65&radioKm=2&idMascotaExcluir=1",
              "host": ["{{geo_url}}"],
              "path": ["api", "geolocalizacion", "cercanas"],
              "query": [
                { "key": "latitud", "value": "-33.45" },
                { "key": "longitud", "value": "-70.65" },
                { "key": "radioKm", "value": "2" },
                { "key": "idMascotaExcluir", "value": "1" }
              ]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "status": "OK",
              "body": "{\n  \"total\": 1,\n  \"radio_km\": 2,\n  \"mascotas\": [\n    { \"mascota\": { \"idMascota\": 2 }, \"distancia_km\": 0.8 }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Calcular distancia entre dos mascotas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{geo_url}}/api/geolocalizacion/distancia?idMascota1=1&idMascota2=2",
              "host": ["{{geo_url}}"],
              "path": ["api", "geolocalizacion", "distancia"],
              "query": [
                { "key": "idMascota1", "value": "1" },
                { "key": "idMascota2", "value": "2" }
              ]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "status": "OK",
              "body": "0.8"
            },
            {
              "name": "404 Not Found",
              "code": 404,
              "status": "Not Found",
              "body": ""
            }
          ]
        },
        {
          "name": "Coincidencias geolocalizadas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{geo_url}}/api/geolocalizacion/coincidencias/1?radioKm=2",
              "host": ["{{geo_url}}"],
              "path": ["api", "geolocalizacion", "coincidencias", "1"],
              "query": [{ "key": "radioKm", "value": "2" }]
            }
          },
          "response": []
        },
        {
          "name": "Obtener todas las ubicaciones",
          "request": {
            "method": "GET",
            "url": { "raw": "{{geo_url}}/api/geolocalizacion/todas", "host": ["{{geo_url}}"], "path": ["api", "geolocalizacion", "todas"] }
          },
          "response": []
        }
      ]
    }
